# ============================================
# MatchPulse Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Server ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/matchpulse?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Twilio (SMS OTP) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- AWS ---
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=matchpulse-uploads
AWS_CLOUDFRONT_URL=https://dxxxxxxxxxx.cloudfront.net

# --- AWS SES (Email) ---
AWS_SES_FROM_EMAIL=admin@scaleupapp.club

# --- Anthropic (AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@matchpulse.in

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
